# Vettri TN — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── OpenAI (Vettri AI Chatbot) ───────────────────────────────────────────────
# Get your key from: https://platform.openai.com/api-keys
# Expo only exposes variables prefixed with EXPO_PUBLIC_ to client-side code.
# This is fine for local demos, but production apps should proxy OpenAI calls through a backend.
EXPO_PUBLIC_OPENAI_API_KEY=sk-your-openai-api-key-here

# ── App Config ────────────────────────────────────────────────────────────────
APP_ENV=development        # development | staging | production
APP_VERSION=1.0.0

# ── API Base URLs ─────────────────────────────────────────────────────────────
# Replace with actual Tamil Nadu govt API endpoints when available
API_BASE_URL=https://api.vettritn.gov.in/v1
GRIEVANCE_API_URL=https://grievance.vettritn.gov.in/api
SCHEMES_API_URL=https://schemes.vettritn.gov.in/api

# ── Analytics (Optional) ─────────────────────────────────────────────────────
# FIREBASE_API_KEY=your-firebase-key
# SENTRY_DSN=your-sentry-dsn
