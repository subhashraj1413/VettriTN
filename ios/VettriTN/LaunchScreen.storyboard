<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!--
  Vettri TN — iOS Launch Screen
  TVK Official Colors:
    Background : #C41E3A  (TVK Maroon-Red)
    Logo ring  : #F5C518  (TVK Golden Yellow)
    Text       : #FFFFFF  (White)

  Layout:
    Full red background → centered VTN logo ring → app name below
    Flag stripe bar at very bottom (maroon | yellow | maroon)
-->
<document
  type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB"
  version="3.0"
  toolsVersion="21701"
  targetRuntime="AppleCocoa"
  propertyAccessControl="none"
  useAutolayout="YES"
  launchScreen="YES"
  useTraitCollections="YES"
  colorMatched="YES">

  <device id="retina6_12" orientation="portrait" appearance="light" />

  <dependencies>
    <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="21678" />
    <capability name="Safe area layout guides" minToolsVersion="9.0" />
    <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0" />
  </dependencies>

  <scenes>
    <scene sceneID="tne-QT-ifu">
      <objects>
        <viewController
          id="01J-lp-oVM"
          sceneMemberID="viewController">

          <view
            key="view"
            contentMode="scaleToFill"
            id="Ze5-6b-2t3">

            <rect key="frame" x="0.0" y="0.0" width="393" height="852" />

            <subviews>

              <!-- ── TVK Red Full Background ──────────────────────── -->
              <view
                contentMode="scaleToFill"
                translatesAutoresizingMaskIntoConstraints="NO"
                id="bg-view">
                <rect key="frame" x="0.0" y="0.0" width="393" height="852" />
                <color key="backgroundColor" red="0.769" green="0.118" blue="0.227" alpha="1" />
              </view>

              <!-- ── Dark Maroon Top Accent Circle ───────────────── -->
              <view
                contentMode="scaleToFill"
                translatesAutoresizingMaskIntoConstraints="NO"
                id="circle-top"
                layer.cornerRadius="150">
                <rect key="frame" x="243" y="-80" width="300" height="300" />
                <color key="backgroundColor" red="0.545" green="0.0" blue="0.0" alpha="0.3" />
              </view>

              <!-- ── Dark Maroon Bottom Accent Circle ────────────── -->
              <view
                contentMode="scaleToFill"
                translatesAutoresizingMaskIntoConstraints="NO"
                id="circle-bot"
                layer.cornerRadius="150">
                <rect key="frame" x="-80" y="632" width="300" height="300" />
                <color key="backgroundColor" red="0.545" green="0.0" blue="0.0" alpha="0.3" />
              </view>

              <!-- ── Logo Outer Ring (TVK Yellow) ─────────────────── -->
              <view
                contentMode="scaleToFill"
                translatesAutoresizingMaskIntoConstraints="NO"
                id="logo-outer"
                layer.cornerRadius="60">
                <rect key="frame" x="136.5" y="300" width="120" height="120" />
                <color key="backgroundColor" red="0.961" green="0.773" blue="0.094" alpha="1" />

                <!-- ── Logo Inner Circle (TVK Red) ──────────────── -->
                <subviews>
                  <view
                    contentMode="scaleToFill"
                    translatesAutoresizingMaskIntoConstraints="NO"
                    id="logo-inner"
                    layer.cornerRadius="40">
                    <rect key="frame" x="20" y="20" width="80" height="80" />
                    <color key="backgroundColor" red="0.769" green="0.118" blue="0.227" alpha="1" />

                    <!-- ── VTN Text ─────────────────────────────── -->
                    <subviews>
                      <label
                        opaque="NO"
                        userInteractionEnabled="NO"
                        contentMode="left"
                        horizontalHuggingPriority="251"
                        verticalHuggingPriority="251"
                        text="VTN"
                        textAlignment="center"
                        lineBreakMode="middleTruncation"
                        baselineAdjustment="alignBaselines"
                        adjustsFontSizeToFit="NO"
                        translatesAutoresizingMaskIntoConstraints="NO"
                        id="vtn-label">
                        <rect key="frame" x="0.0" y="22" width="80" height="36" />
                        <fontDescription key="fontDescription" type="system" pointSize="20" />
                        <color key="textColor" red="0.961" green="0.773" blue="0.094" alpha="1" />
                        <nil key="highlightedTextColor" />
                      </label>
                    </subviews>

                    <constraints>
                      <constraint firstItem="vtn-label" firstAttribute="centerX" secondItem="logo-inner" secondAttribute="centerX" id="c-lbl-cx" />
                      <constraint firstItem="vtn-label" firstAttribute="centerY" secondItem="logo-inner" secondAttribute="centerY" id="c-lbl-cy" />
                      <constraint firstItem="vtn-label" firstAttribute="width" secondItem="logo-inner" secondAttribute="width" id="c-lbl-w" />
                    </constraints>
                  </view>
                </subviews>

                <constraints>
                  <constraint firstItem="logo-inner" firstAttribute="centerX" secondItem="logo-outer" secondAttribute="centerX" id="c-inner-cx" />
                  <constraint firstItem="logo-inner" firstAttribute="centerY" secondItem="logo-outer" secondAttribute="centerY" id="c-inner-cy" />
                  <constraint firstItem="logo-inner" firstAttribute="width"  constant="80" id="c-inner-w" />
                  <constraint firstItem="logo-inner" firstAttribute="height" constant="80" id="c-inner-h" />
                </constraints>
              </view>

              <!-- ── App Name Label ─────────────────────────────────── -->
              <label
                opaque="NO"
                userInteractionEnabled="NO"
                contentMode="left"
                horizontalHuggingPriority="251"
                verticalHuggingPriority="251"
                text="Vettri TN"
                textAlignment="center"
                lineBreakMode="middleTruncation"
                baselineAdjustment="alignBaselines"
                adjustsFontSizeToFit="NO"
                translatesAutoresizingMaskIntoConstraints="NO"
                id="app-name-label">
                <rect key="frame" x="0.0" y="438" width="393" height="40" />
                <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="32" />
                <color key="textColor" red="1.0" green="1.0" blue="1.0" alpha="1" />
                <nil key="highlightedTextColor" />
              </label>

              <!-- ── Tamil subtitle ─────────────────────────────────── -->
              <label
                opaque="NO"
                userInteractionEnabled="NO"
                contentMode="left"
                horizontalHuggingPriority="251"
                verticalHuggingPriority="251"
                text="வெற்றி தமிழ்நாடு"
                textAlignment="center"
                lineBreakMode="middleTruncation"
                baselineAdjustment="alignBaselines"
                adjustsFontSizeToFit="NO"
                translatesAutoresizingMaskIntoConstraints="NO"
                id="tamil-label">
                <rect key="frame" x="0.0" y="484" width="393" height="24" />
                <fontDescription key="fontDescription" type="system" pointSize="16" />
                <color key="textColor" red="0.961" green="0.773" blue="0.094" alpha="1" />
                <nil key="highlightedTextColor" />
              </label>

              <!-- ── Tagline ─────────────────────────────────────────── -->
              <label
                opaque="NO"
                userInteractionEnabled="NO"
                contentMode="left"
                horizontalHuggingPriority="251"
                verticalHuggingPriority="251"
                text="Citizen Super App"
                textAlignment="center"
                lineBreakMode="middleTruncation"
                baselineAdjustment="alignBaselines"
                adjustsFontSizeToFit="NO"
                translatesAutoresizingMaskIntoConstraints="NO"
                id="tagline-label">
                <rect key="frame" x="0.0" y="516" width="393" height="20" />
                <fontDescription key="fontDescription" type="system" pointSize="14" />
                <color key="textColor" red="1.0" green="1.0" blue="1.0" alpha="0.7" />
                <nil key="highlightedTextColor" />
              </label>

              <!-- ── TVK Flag Color Strip (bottom) ──────────────────── -->
              <!-- Maroon band (left) -->
              <view
                contentMode="scaleToFill"
                translatesAutoresizingMaskIntoConstraints="NO"
                id="flag-maroon-1">
                <rect key="frame" x="136.5" y="790" width="40" height="8" />
                <color key="backgroundColor" red="0.545" green="0.0" blue="0.0" alpha="1" />
              </view>
              <!-- Yellow band (center) -->
              <view
                contentMode="scaleToFill"
                translatesAutoresizingMaskIntoConstraints="NO"
                id="flag-yellow">
                <rect key="frame" x="176.5" y="790" width="40" height="8" />
                <color key="backgroundColor" red="0.961" green="0.773" blue="0.094" alpha="1" />
              </view>
              <!-- Maroon band (right) -->
              <view
                contentMode="scaleToFill"
                translatesAutoresizingMaskIntoConstraints="NO"
                id="flag-maroon-2">
                <rect key="frame" x="216.5" y="790" width="40" height="8" />
                <color key="backgroundColor" red="0.545" green="0.0" blue="0.0" alpha="1" />
              </view>

            </subviews>

            <color key="backgroundColor" red="0.769" green="0.118" blue="0.227" alpha="1" />

            <constraints>
              <constraint firstItem="bg-view" firstAttribute="top"     secondItem="Ze5-6b-2t3" secondAttribute="top"    id="c-bg-t" />
              <constraint firstItem="bg-view" firstAttribute="bottom"  secondItem="Ze5-6b-2t3" secondAttribute="bottom" id="c-bg-b" />
              <constraint firstItem="bg-view" firstAttribute="leading" secondItem="Ze5-6b-2t3" secondAttribute="leading" id="c-bg-l" />
              <constraint firstItem="bg-view" firstAttribute="trailing" secondItem="Ze5-6b-2t3" secondAttribute="trailing" id="c-bg-r" />

              <constraint firstItem="logo-outer" firstAttribute="centerX" secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="c-logo-cx" />
              <constraint firstItem="logo-outer" firstAttribute="centerY" secondItem="Ze5-6b-2t3" secondAttribute="centerY" constant="-60" id="c-logo-cy" />
              <constraint firstItem="logo-outer" firstAttribute="width"  constant="120" id="c-logo-w" />
              <constraint firstItem="logo-outer" firstAttribute="height" constant="120" id="c-logo-h" />

              <constraint firstItem="app-name-label" firstAttribute="centerX"  secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="c-name-cx" />
              <constraint firstItem="app-name-label" firstAttribute="top"      secondItem="logo-outer"  secondAttribute="bottom"  constant="24" id="c-name-t" />
              <constraint firstItem="app-name-label" firstAttribute="leading"  secondItem="Ze5-6b-2t3" secondAttribute="leading"  constant="16" id="c-name-l" />
              <constraint firstItem="app-name-label" firstAttribute="trailing" secondItem="Ze5-6b-2t3" secondAttribute="trailing" constant="-16" id="c-name-r" />

              <constraint firstItem="tamil-label" firstAttribute="centerX" secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="c-tam-cx" />
              <constraint firstItem="tamil-label" firstAttribute="top"     secondItem="app-name-label" secondAttribute="bottom" constant="6" id="c-tam-t" />

              <constraint firstItem="tagline-label" firstAttribute="centerX" secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="c-tag-cx" />
              <constraint firstItem="tagline-label" firstAttribute="top"     secondItem="tamil-label" secondAttribute="bottom" constant="8" id="c-tag-t" />

              <constraint firstItem="flag-yellow" firstAttribute="centerX"  secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="c-fy-cx" />
              <constraint firstItem="flag-yellow" firstAttribute="bottom"   secondItem="Ze5-6b-2t3" secondAttribute="bottom"   constant="-40" id="c-fy-b" />
              <constraint firstItem="flag-maroon-1" firstAttribute="trailing" secondItem="flag-yellow" secondAttribute="leading" id="c-fm1-r" />
              <constraint firstItem="flag-maroon-2" firstAttribute="leading"  secondItem="flag-yellow" secondAttribute="trailing" id="c-fm2-l" />
            </constraints>

          </view>
        </viewController>

        <placeholder placeholderIdentifier="IBFirstResponder" id="iYj-Kq-Ea1" userLabel="First Responder" sceneMemberID="firstResponder" />
      </objects>

      <point key="canvasLocation" x="53" y="375" />
    </scene>
  </scenes>

</document>
